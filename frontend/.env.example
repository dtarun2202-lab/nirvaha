# Firebase Client Configuration for Frontend
# Rename this file to .env or .env.local in the frontend directory and fill in your actual credentials.
# Once these variables are configured, the frontend will switch from Mock Bypass Mode to real Firebase OAuth.

VITE_FIREBASE_API_KEY=your-actual-firebase-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
VITE_FIREBASE_APP_ID=your-app-id
